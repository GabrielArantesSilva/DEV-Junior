generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ServiceOrder {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  client      String
  date        DateTime
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
}